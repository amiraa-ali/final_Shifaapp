              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('appointmentId', res.data._id);",
                  "  pm.test('Appointment created', () => pm.expect(res.success).to.be.true);",
