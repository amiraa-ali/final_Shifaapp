{
  "info": {
    "name": "Healthcare App API",
    "description": "Complete REST API collection for Healthcare Mobile App (Flutter)\n\n## Setup\n1. Set `baseUrl` variable to your server URL (default: http://localhost:5000)\n2. Register a user to get a token\n3. The token is auto-saved to `authToken` variable after login/register\n\n## Roles\n- **Doctor**: Can manage profile, view/manage appointments, update patient medical conditions\n- **Patient**: Can manage personal info, book appointments, view medical conditions (read-only)",
    "_postman_id": "healthcare-api-collection-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "doctorId",
      "value": "",
      "type": "string"
    },
    {
      "key": "patientId",
      "value": "",
      "type": "string"
    },
    {
      "key": "appointmentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('authToken', res.data.token);",
                  "  pm.collectionVariables.set('doctorId', res.data.user._id);",
                  "  pm.test('Registration successful', () => pm.expect(res.success).to.be.true);",
                  "  pm.test('Token received', () => pm.expect(res.data.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Ahmed Hassan\",\n  \"email\": \"doctor@healthcare.com\",\n  \"password\": \"password123\",\n  \"role\": \"doctor\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {"raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"]}
          }
        },
        {
          "name": "Register Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('authToken', res.data.token);",
                  "  pm.collectionVariables.set('patientId', res.data.user._id);",
                  "  pm.test('Registration successful', () => pm.expect(res.success).to.be.true);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sara Ali\",\n  \"email\": \"patient@healthcare.com\",\n  \"password\": \"password123\",\n  \"role\": \"patient\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {"raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"]}
          }
        },
        {
          "name": "Login Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('authToken', res.data.token);",
                  "  pm.test('Login successful', () => pm.expect(res.success).to.be.true);",
                  "  pm.test('Token received', () => pm.expect(res.data.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doctor@healthcare.com\",\n  \"password\": \"password123\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {"raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"]}
          }
        },
        {
          "name": "Login Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
